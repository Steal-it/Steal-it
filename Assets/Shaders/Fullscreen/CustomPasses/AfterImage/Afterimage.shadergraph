{
    "m_SGVersion": 1,
    "m_Type": "UnityEditor.ShaderGraph.CustomFunctionNode",
    "m_ObjectId": "075c6d6f973845cabf8155766856c31a",
    "m_Group": {
        "m_Id": ""
    },
    "m_Name": "FrameBuffer (Custom Function)",
    "m_DrawState": {
        "m_Expanded": true,
        "m_Position": {
            "serializedVersion": "2",
            "x": -1004.0,
            "y": -334.9999694824219,
            "width": 225.0,
            "height": 93.99996948242188
        }
    },
    "m_Slots": [
        {
            "m_Id": "b325526a80624dd08e64f5673761eabc"
        },
        {
            "m_Id": "0bb502453b384af082d2045a659ab3cc"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": false,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "FrameBuffer",
    "m_FunctionSource": "8afa94f92f3d9674baabe856c9e70961",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "#include \"Packages/com.unity.render-pipelines.universal/ShaderLibrary/Core.hlsl\"\r\n\n#pragma vertex Vert\r\n           #pragma fragment Frag\r\n           #pragma target 4.5\r\n           #pragma require msaatex\r\n\r\n           // Declares the framebuffer input as a texture 2d containing half.\r\n           FRAMEBUFFER_INPUT_HALF_MS(0);\r\n\r\n           // Out frag function takes as input a struct that contains the screen space coordinate we are going to use to sample our texture. It also writes to SV_Target0, this has to match the index set in the UseTextureFragment(sourceTexture, 0, …) we defined in our render pass script.   \r\n           float4 Frag(Varyings input, uint sampleID : SV_SampleIndex) : SV_Target0\r\n           {\r\n               // this is needed so we account XR platform differences in how they handle texture arrays\r\n               UNITY_SETUP_STEREO_EYE_INDEX_POST_VERTEX(input);\r\n\r\n               // read the current pixel from the framebuffer\r\n               //float2 uv = input.texcoord.xy;\r\n               // read previous subpasses directly from the framebuffer.\r\n               half4 color = LOAD_FRAMEBUFFER_INPUT_MS(0, sampleID, input.positionCS.xy);\r\n               \r\n               // Modify the sampled color\r\n               return half4(0,0,1,1) * color;\r\n           }"
}

